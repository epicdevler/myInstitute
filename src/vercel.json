{
  "rewrites": [
    {
      "source": "/",
      "destination": "/(website)",
      "has": [
        {
          "type": "host",
          "value": "www.websitedomain.com" 
        }
      ]
    },
    {
      "source": "/",
      "destination": "/(app)/dashboard",
      "has": [
        {
          "type": "host",
          "value": "app.websitedomain.com" 
        }
      ]
    }
  ]
}
